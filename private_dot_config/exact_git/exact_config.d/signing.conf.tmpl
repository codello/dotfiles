[user]
    {{- if .personal }}
	signingkey = "{{ onepasswordRead "op://Private/Git Signing Key/public key" "my.1password.eu" }}"
	{{- end }}
	{{- if .work }}
	signingkey = "{{ (bitwarden "item" "Git Signing Key").sshKey.publicKey }}"
	{{- end }}

[credential]
	helper = osxkeychain

[gpg]
	format = ssh

[gpg "ssh"]
{{- if .personal }}
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
{{- end }}
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgsign = true
