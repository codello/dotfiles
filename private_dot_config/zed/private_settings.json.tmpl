// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // Extensions
  "auto_install_extensions": {
    // Themes and Visuals
    "jetbrains-themes": true,
    "catppuccin-icons": true,
    // Languages
    "comment": true, // highlights todo comments
    "dockerfile": true,
    "gotmpl": true,
    "html": true,
    "toml": true,
  },

  // General Settings
  "base_keymap": "JetBrains",

  // Appearance & Layout
  "icon_theme": "Catppuccin Latte",
  "theme": {
    "mode": "system",
    "light": "JetBrains Light",
    "dark": "JetBrains Dark",
  },
  "drop_target_size": 0.35,
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "status_bar": {
    "line_endings_button": true,
  },
  "project_panel": {
    "dock": "left",
    "hide_root": true,
    "diagnostic_badges": true,
  },
  "git_panel": {
    "dock": "left",
    "sort_by": "path",
  },

  // Fonts
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 13.0,
  "buffer_font_weight": 300.0,
  "buffer_line_height": {
    "custom": 1.35,
  },

  // Editor Experience
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "close_on_file_delete": true,
  "auto_signature_help": false,
  "show_signature_help_after_edits": true,
  "gutter": {
    "min_line_number_digits": 3,
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.75,
  },
  "colorize_brackets": true,
  "wrap_guides": [80, 120],
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "scrollbar": {
    "show": "system",
  },
  "unnecessary_code_fade": 0.4,

  // Code Intelligence
  "inlay_hints": {
    "enabled": true,
    "edit_debounce_ms": 0,
    "scroll_debounce_ms": 0,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "padding": 8,
    },
  },

  // Git Integration
  "diff_view_style": "unified",
  "git": {
    "branch_picker": {
      "show_author_name": true,
    },
  },

  // AI Settings
  "show_edit_predictions": {{ .personal }},
  "edit_predictions": {
    "allow_data_collection": "no",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },
  {{ if .work -}}
  "language_models": {
    "litellm": {
      "api_url": "{{ (index (bitwarden "item" "AI Keys").login.uris 0).uri }}",
    },
  },
  {{- end }}
  "agent": {
    "profiles": {
      "agent": {
        "name": "Coding Agent",
        "enable_all_context_servers": true,
        "tools": {
          "copy_path": true,
          "create_directory": true,
          "create_thread": true,
          "delete_path": true,
          "diagnostics": true,
          "apply_code_action": true,
          "edit_file": true,
          "write_file": true,
          "fetch": true,
          "find_path": true,
          "find_references": true,
          "get_code_actions": true,
          "go_to_definition": true,
          "list_agents_and_models": true,
          "list_directory": true,
          "move_path": true,
          "rename_symbol": true,
          "read_file": true,
          "grep": true,
          "skill": true,
          "spawn_agent": true,
          "terminal": true,
          "search_web": true,
        },
        "context_servers": {
          "github": {
            // See https://github.com/github/github-mcp-server#tools
            "tools": {
              // Actions
              "actions_get": true,
              "actions_list": true,
              "actions_run_trigger": true,
              "get_job_logs": true,
              // Code Quality
              "get_code_quality_finding": false,
              // Code Security
              "get_code_scanning_alert": false,
              "list_code_scanning_alerts": false,
              // Context
              "get_team_members": false,
              "get_teams": false,
              // Copilot
              "assign_copilot_to_issue": false,
              "request_copilot_review": false,
              // Copilot Issue Intents
              "assign_copilot_to_issue_with_intent": false,
              // Dependabot
              "get_dependabot_alert": false,
              "list_dependabot_alerts": false,
              // Discussions
              "discussion_comment_write": false,
              "get_discussion": false,
              "get_discussion_comments": false,
              "list_discussion_categories": false,
              "list_discussions": false,
              // Gists
              "create_gist": false,
              "get_gist": true,
              "list_gists": false,
              "update_gist": false,
              // Git
              "get_repository_tree": true,
              // Issues
              "add_issue_comment": false,
              "issue_read": true,
              "issue_write": true,
              "list_issue_fields": false,
              "list_issue_types": false,
              "list_issues": true,
              "search_issues": true,
              "sub_issue_write": true,
              // Labels
              "get_label": false,
              "label_write": false,
              "list_label": false,
              // Notifications
              "dismiss_notification": false,
              "get_notification_details": false,
              "list_notifications": false,
              "manage_notification_subscription": false,
              "manage_repository_notification_subscription": false,
              "mark_all_notifications_read": false,
              // Organizations
              "search_orgs": false,
              // Projects
              "projects_get": true,
              "projects_list": true,
              "projects_write": false,
              // Pull Requests
              "add_comment_to_pending_review": true,
              "add_reply_to_pull_request_comment": false,
              "create_pull_request": true,
              "list_pull_requests": true,
              "merge_pull_request": false,
              "pull_request_read": true,
              "pull_request_review_write": true,
              "search_pull_requests": true,
              "update_pull_request": true,
              "update_pull_request_branch": false,
              // Repositories
              "create_branch": false,
              "create_or_update_file": false,
              "create_repository": false,
              "delete_file": false,
              "fork_repository": false,
              "get_commit": true,
              "get_file_contents": true,
              "get_latest_release": false,
              "get_release_by_tag": false,
              "get_tag": false,
              "list_branches": false,
              "list_commits": true,
              "list_releases": false,
              "list_repository_collaborators": false,
              "list_tags": false,
              "push_files": false,
              "search_code": true,
              "search_commits": true,
              "search_repositories": true,
              // Secret Protection
              "get_secret_scanning_alert": false,
              "list_secret_scanning_alerts": false,
              "run_secret_scanning": false,
              // Security Advisories
              "get_global_security_advisory": false,
              "list_global_security_advisories": false,
              "list_org_repository_security_advisories": false,
              "list_repository_security_advisories": false,
              // Stargazers
              "list_starred_repositories": false,
              "star_repository": false,
              "unstar_repository": false,
              // Users
              "search_users": false,
              // Copilot Remote
              "create_pull_request_with_copilot": false,
              "get_copilot_space": false,
              "github_support_docs_search": true,
            },
          },
          "dataverse": {
            // See https://learn.microsoft.com/en-us/power-apps/maker/data-platform/data-platform-mcp#list-of-tools
            "tools": {
              "search_data": true,
              "search": true,
              "create_record": false,
              "update_record": false,
              "delete_record": false,
              "create_table": true,
              "update_table": true,
              "delete_table": false,
              "read_query": true,
              "describe": true,
              "upsert_skill": false,
              "delete_skill": false,
              "init_file_upload": false,
              "commit_file_upload": false,
              "file_download": false,
            },
          },
        },
      },
      "write": {
        "name": "Write",
        "enable_all_context_servers": false,
      },
    },
    "tool_permissions": {
      "tools": {
        "fetch": { "default": "allow" },
        "create_directory": { "default": "allow" },
        "copy_path": { "default": "allow" },
        "delete_path": { "default": "allow" },
        "terminal": {
          "always_allow": [
            {
              "pattern": "",
            },
          ],
        },

        // See https://github.com/github/github-mcp-server#tools
        "mcp:github:actions_get": { "default": "allow" },
        "mcp:github:get_job_logs": { "default": "allow" },
        "mcp:github:actions_list": { "default": "allow" },
        "mcp:github:get_me": { "default": "allow" },
        "mcp:github:get_gist": { "default": "allow" },
        "mcp:github:get_repository_tree": { "default": "allow" },
        "mcp:github:issue_read": { "default": "allow" },
        "mcp:github:list_issues": { "default": "allow" },
        "mcp:github:search_issues": { "default": "allow" },
        "mcp:github:projects_list": { "default": "allow" },
        "mcp:github:add_comment_to_pending_review": { "default": "allow" },
        "mcp:github:list_pull_requests": { "default": "allow" },
        "mcp:github:pull_request_read": { "default": "allow" },
        "mcp:github:search_pull_requests": { "default": "allow" },
        "mcp:github:get_commit": { "default": "allow" },
        "mcp:github:get_file_contents": { "default": "allow" },
        "mcp:github:list_commits": { "default": "allow" },
        "mcp:github:search_code": { "default": "allow" },
        "mcp:github:search_commits": { "default": "allow" },
        "mcp:github:search_repositories": { "default": "allow" },
        "mcp:github:github_support_docs_search": { "default": "allow" },

        // See https://learn.microsoft.com/en-us/power-apps/maker/data-platform/data-platform-mcp#list-of-tools
        "mcp:dataverse:search": { "default": "allow" },
        "mcp:dataverse:read_query": { "default": "allow" },
        "mcp:dataverse:describe": { "default": "allow" },

        "mcp:mslearn:microsoft_docs_search": { "default": "allow" },
        "mcp:mslearn:microsoft_docs_fetch": { "default": "allow" },
        "mcp:mslearn:microsoft_docs_code_sample_search": { "default": "allow" },
      },
    },
    {{- if .personal }}
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "openrouter/auto",
        "enable_thinking": true,
      },
      {
        "provider": "openrouter",
        "model": "openrouter/free",
        "enable_thinking": true,
      },
      {
        "provider": "openrouter",
        "model": "z-ai/glm-5.2",
        "enable_thinking": true,
      },
    ],
    {{- end }}
    "show_turn_stats": true,
    "sandbox_permissions": {
      "network_hosts": [
        "github.com",
        "docs.github.com",
        "raw.githubusercontent.com",
        "docs.api.stackit.cloud",
      ],
      "allow_all_hosts": false,
    },
    "thinking_display": "auto",
    "dock": "right",
    "sidebar_side": "right",
    "enable_feedback": false,
    "play_sound_when_agent_done": "always",
    "default_profile": "agent",
    "single_file_review": true,
  },
  "openai_compatible": {
    "OpenRouter (OpenAI Compatible)": {
    "api_url": "https://openrouter.ai/api/v1",
    "available_models": [
      {
        "display_name": "GLM 5.2 (High)",
        "name": "@preset/glm-5-2",
        "max_tokens": 1048576,
        "max_output_tokens": 131072,
        "reasoning_effort": "high",
        "capabilities": {
          "tools": true,
          "images": false,
          "parallel_tool_calls": true,
          "chat_completions": true,
          "interleaved_reasoning": true,
          "prompt_cache_key": false,
          "max_tokens_parameter": true,
        },
      },
      {
        "display_name": "DeepSeek V4 Flash (High)",
        "name": "@preset/deepseek-v4-flash",
        "max_tokens": 1048576,
        "max_output_tokens": 65536,
        "capabilities": {
          "tools": true,
          "images": false,
          "parallel_tool_calls": true,
          "chat_completions": true,
          "interleaved_reasoning": true,
          "prompt_cache_key": false,
          "max_tokens_parameter": true,
        },
      },
    ],
  },
  "context_servers": {
    "GitHub": {
    "enabled": true,
    "url": "https://api.githubcopilot.com/mcp/",
    "headers": {
        "Authorization": "{{if .personal }}Bearer {{ onepasswordRead "op://Private/GitHub/Personal Access Tokens/MCP Personal" "my.1password.eu" }}{{ end }}{{ if .work }}{{ range (bitwarden "item" "d1778be8-ddc4-4f0d-94e3-677cad06bc1c").fields }}{{ if eq .name "MCP PAT" }}{{ .value }}{{ end }}{{ end }}{{ end }}",
      },
    },
  },
  "agent_servers": {
    "{{ if .personal }}github-copilot-cli{{ end }}{{ if .work }}claude-acp{{ end }}": {
      "type": "registry",
    },
  },

  // Terminal
  "terminal": {
    "font_weight": 300.0,
    "font_family": "JetBrainsMono Nerd Font",
    "cursor_shape": "bar",
  },

  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // Profiles
  "profiles": {
    "Presenting (Dark)": {
      "settings": {
        "theme": "JetBrains Dark",
        "agent_buffer_font_size": 18.0,
        "buffer_font_size": 18.0,
        "ui_font_size": 18.0,
      },
    },
    "Presenting (Light)": {
      "settings": {
        "theme": "JetBrains Light",
        "agent_buffer_font_size": 18.0,
        "buffer_font_size": 18.0,
        "ui_font_size": 18.0,
      },
    },
  },

  // Fily Type Associations
  "file_types": {
    "GitHub Actions": ["**/.github/workflows/*"],
    "Go Text Template": ["*.tpl", "**/templates/*.yaml"],
  },

  // Language-specific Settings
  "languages": {
    "Go Text Template": {
      "tab_size": 2,
    },
  },
}
